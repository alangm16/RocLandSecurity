<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="RocLandSecurity.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:guardia="clr-namespace:RocLandSecurity.Views.Guardia"
    xmlns:supervisor="clr-namespace:RocLandSecurity.Views.Supervisor"
    xmlns:shared="clr-namespace:RocLandSecurity.Views.Shared"
    Shell.NavBarIsVisible="False"
    Shell.TabBarBackgroundColor="#111111"
    Shell.TabBarForegroundColor="#6DBF2E"
    Shell.TabBarUnselectedColor="#555555"
    Shell.TabBarTitleColor="#6DBF2E"
    Title="RocLand Security">

    <!--
        ARQUITECTURA DE NAVEGACIÓN
        ─────────────────────────────────────────────────────────────────
        El login (MainPage) NO vive en el Shell. Se muestra como una
        página modal encima del Shell desde App.xaml.cs. Esto garantiza
        que el TabBar solo aparezca abajo, sin ítems mezclados con Login.

        Flujo:
          1. App.xaml.cs crea Window con AppShell + PushModalAsync(MainPage)
          2. Login exitoso → MainPage llama AppShell.MostrarTabBarGuardia/Supervisor
             y hace PopModalAsync para revelar el Shell con el TabBar correcto.
          3. Logout → PerfilPage llama AppShell.Logout() que hace PushModalAsync
             con una nueva MainPage.
        ─────────────────────────────────────────────────────────────────
    -->

    <!-- ══════════════════════════════════════════════════════════
         TAB BAR — GUARDIA
    ══════════════════════════════════════════════════════════ -->
    <TabBar x:Name="TabBarGuardia" Route="guardia">

        <Tab Title="Rondines" Icon="tab_rondin.png" Route="home">
            <ShellContent
                Title="Rondines"
                Route="guardiahome"
                ContentTemplate="{DataTemplate guardia:GuardiaHomePage}"
                Shell.NavBarIsVisible="False"/>
        </Tab>

        <Tab Title="Historial" Icon="tab_historial.png" Route="historial">
            <ShellContent
                Title="Historial"
                Route="guardiahistorial"
                ContentTemplate="{DataTemplate guardia:HistorialGuardiaPage}"
                Shell.NavBarIsVisible="False"/>
        </Tab>

        <Tab Title="Perfil" Icon="tab_perfil.png" Route="perfil">
            <ShellContent
                Title="Perfil"
                Route="guardiaperfil"
                ContentTemplate="{DataTemplate shared:PerfilPage}"
                Shell.NavBarIsVisible="False"/>
        </Tab>

    </TabBar>

    <!-- ══════════════════════════════════════════════════════════
         TAB BAR — SUPERVISOR
    ══════════════════════════════════════════════════════════ -->
    <TabBar x:Name="TabBarSupervisor" Route="supervisor">

        <Tab Title="Panel" Icon="tab_panel.png" Route="panel">
            <ShellContent
                Title="Panel"
                Route="supervisorhome"
                ContentTemplate="{DataTemplate supervisor:SupervisorHomePage}"
                Shell.NavBarIsVisible="False"/>
        </Tab>

        <Tab Title="Incidencias" Icon="tab_incidencia.png" Route="incidencias">
            <ShellContent
                Title="Incidencias"
                Route="supervisorincidencias"
                ContentTemplate="{DataTemplate supervisor:SupervisorIncidenciasPage}"
                Shell.NavBarIsVisible="False"/>
        </Tab>

        <Tab Title="Historial" Icon="tab_historial.png" Route="historial">
            <ShellContent
                Title="Historial"
                Route="supervisorhistorial"
                ContentTemplate="{DataTemplate supervisor:SupervisorHistorialPage}"
                Shell.NavBarIsVisible="False"/>
        </Tab>

        <Tab Title="Perfil" Icon="tab_perfil.png" Route="perfil">
            <ShellContent
                Title="Perfil"
                Route="supervisorperfil"
                ContentTemplate="{DataTemplate shared:PerfilPage}"
                Shell.NavBarIsVisible="False"/>
        </Tab>

    </TabBar>

</Shell>