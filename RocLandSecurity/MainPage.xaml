<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RocLandSecurity.MainPage">

    <VerticalStackLayout Padding="30" Spacing="20">
        <Label Text="Login ROCLAND" FontSize="24" HorizontalOptions="Center"/>
        <Entry x:Name="UsuarioEntry" Placeholder="Usuario"/>
        <Entry x:Name="ContrasenaEntry" Placeholder="Contraseña" IsPassword="True"/>
        <Button Text="Ingresar" Clicked="OnLoginClicked"/>
    </VerticalStackLayout>

</ContentPage>
