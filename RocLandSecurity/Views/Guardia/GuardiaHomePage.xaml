<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RocLandSecurity.Views.Guardia.GuardiaHomePage"
             BackgroundColor="#111111"
             Shell.NavBarIsVisible="False">

	<ContentPage.Resources>
		<ResourceDictionary>
			<Color x:Key="AccentGreen">#6DBF2E</Color>
			<Color x:Key="CardBg">#1A1A1A</Color>
			<Color x:Key="TextPrimary">#FFFFFF</Color>
			<Color x:Key="TextSecondary">#888888</Color>
			<Color x:Key="BorderColor">#2A2A2A</Color>
			<Color x:Key="SectionLabel">#666666</Color>
		</ResourceDictionary>
	</ContentPage.Resources>

	<Grid RowDefinitions="Auto,*">

		<!-- ══════════════════════════════════════════════════
             HEADER — icono campana + título + fecha
        ══════════════════════════════════════════════════ -->
		<Grid Grid.Row="0"
              BackgroundColor="#1A1A1A"
              Padding="20,48,20,16"
              ColumnDefinitions="Auto,*">

			<!-- Icono campana con badge verde -->
			<Border Grid.Column="0"
                    BackgroundColor="#1A2E1A"
                    StrokeThickness="0"
                    WidthRequest="40" HeightRequest="40"
                    VerticalOptions="Center"
                    Margin="0,0,12,0">
				<Border.StrokeShape>
					<RoundRectangle CornerRadius="12"/>
				</Border.StrokeShape>
				<Image Source="alert.png"
                       WidthRequest="24"
					   HeightRequest="24"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
			</Border>

			<VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
				<Label x:Name="LblNombre"
                       Text="Rondines"
                       TextColor="{StaticResource TextPrimary}"
                       FontSize="20" FontAttributes="Bold"
                       LineBreakMode="TailTruncation"/>
				<Label x:Name="LblFechaTurno"
                       Text="Turno nocturno · --"
                       TextColor="{StaticResource TextSecondary}"
                       FontSize="13"/>
			</VerticalStackLayout>
		</Grid>

		<!-- ══════════════════════════════════════════════════
             CONTENIDO
        ══════════════════════════════════════════════════ -->
		<ScrollView Grid.Row="1">
			<VerticalStackLayout Padding="16,14,16,24" Spacing="0">

				<!-- Cargando -->
				<ActivityIndicator x:Name="LoadingIndicator"
                                   IsRunning="True" IsVisible="True"
                                   Color="{StaticResource AccentGreen}"
                                   HeightRequest="48"
                                   Margin="0,32,0,0"/>

				<!-- ── SIN TURNO ───────────────────────────── -->
				<VerticalStackLayout x:Name="PanelSinTurno"
                                     IsVisible="False"
                                     HorizontalOptions="Center"
                                     Spacing="14"
                                     Margin="0,48,0,0">
					<Label Text="🌙"
                           FontSize="48"
                           HorizontalOptions="Center"/>
					<Label Text="Sin turno activo"
                           TextColor="{StaticResource TextPrimary}"
                           FontSize="18" FontAttributes="Bold"
                           HorizontalOptions="Center"/>
					<Label Text="No hay un turno registrado para hoy."
                           TextColor="{StaticResource TextSecondary}"
                           FontSize="14"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"
                           Margin="0,0,0,8"/>
					<Button x:Name="BtnIniciarTurno"
                            Text="Iniciar turno de hoy"
                            BackgroundColor="{StaticResource AccentGreen}"
                            TextColor="#111111"
                            FontAttributes="Bold"
                            FontSize="15"
                            CornerRadius="14"
                            HeightRequest="54"
                            HorizontalOptions="Fill"
                            Clicked="OnIniciarTurnoClicked"/>
				</VerticalStackLayout>

				<!-- ── RONDINES ────────────────────────────── -->
				<VerticalStackLayout x:Name="PanelRondines"
                                     IsVisible="False"
                                     Spacing="0">

					<!-- Tarjeta rondín en progreso (se construye en code-behind) -->
					<Label x:Name="LblSeccionEnProgreso"
						   Text="EN PROGRESO"
						   TextColor="{StaticResource SectionLabel}"
						   FontSize="11" FontAttributes="Bold"
						   Margin="4,0,0,8"
						   IsVisible="False"/>
					<VerticalStackLayout x:Name="PanelEnProgreso" IsVisible="False" Margin="0,0,0,20">
						<!-- Filled by code-behind -->
					</VerticalStackLayout>

					<!-- Sección: Pendientes -->
					<Label x:Name="LblSeccionPendientes"
                           Text="PENDIENTES"
                           TextColor="{StaticResource SectionLabel}"
                           FontSize="11" FontAttributes="Bold"
                           Margin="4,0,0,8"
                           IsVisible="False"/>
					<VerticalStackLayout x:Name="ListaPendientes" Spacing="10" Margin="0,0,0,20"/>

					<!-- Sección: Completados hoy -->
					<Label x:Name="LblSeccionCompletados"
                           Text="COMPLETADOS HOY"
                           TextColor="{StaticResource SectionLabel}"
                           FontSize="11" FontAttributes="Bold"
                           Margin="4,0,0,8"
                           IsVisible="False"/>
					<VerticalStackLayout x:Name="ListaCompletados" Spacing="10"/>

					<!-- Espaciado para el TabBar -->
					<!-- <BoxView HeightRequest="32" Color="Transparent"/> -->

				</VerticalStackLayout>

			</VerticalStackLayout>
		</ScrollView>

		<!-- Toast -->
		<Frame x:Name="ToastFrame"
               Grid.Row="0" Grid.RowSpan="2"
               BackgroundColor="#FF5555"
               CornerRadius="12" Padding="14,10"
               IsVisible="False"
               HorizontalOptions="Center"
               VerticalOptions="Start"
               Margin="20,56,20,0"
               HasShadow="True" Opacity="0"
               ZIndex="100">
			<Label x:Name="ToastLabel"
                   TextColor="White"
                   FontAttributes="Bold"
                   FontSize="13"
                   HorizontalOptions="Center"/>
		</Frame>

	</Grid>
</ContentPage>
