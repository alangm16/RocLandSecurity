<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RocLandSecurity.Views.Guardia.GuardiaHomePage"
             BackgroundColor="#111111"
             Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="AccentGreen">#6DBF2E</Color>
            <Color x:Key="CardBg">#1C1C1C</Color>
            <Color x:Key="TextPrimary">#FFFFFF</Color>
            <Color x:Key="TextSecondary">#888888</Color>
            <Color x:Key="BorderColor">#2E2E2E</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">

        <!-- ══════════════════════════════════════════════════
             HEADER
        ══════════════════════════════════════════════════ -->
        <Grid Grid.Row="0"
              BackgroundColor="#1C1C1C"
              Padding="20,48,20,16"
              ColumnDefinitions="*,Auto">

            <VerticalStackLayout Grid.Column="0" Spacing="2">
                <Label x:Name="LblBienvenida"
                       Text="Bienvenido"
                       TextColor="{StaticResource TextSecondary}"
                       FontSize="13"/>
                <Label x:Name="LblNombre"
                       Text="--"
                       TextColor="{StaticResource TextPrimary}"
                       FontSize="20" FontAttributes="Bold"/>
                <Label x:Name="LblFechaTurno"
                       Text="--"
                       TextColor="{StaticResource TextSecondary}"
                       FontSize="12"/>
            </VerticalStackLayout>

            <!-- Badge de turno activo / inactivo -->
            <Border Grid.Column="1"
                    x:Name="BadgeTurno"
                    BackgroundColor="#0a1a0a"
                    StrokeThickness="1" Stroke="#97C459"
                    Padding="10,6"
                    VerticalOptions="Center">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20"/>
                </Border.StrokeShape>
                <Label x:Name="LblBadgeTurno"
                       Text="Turno activo"
                       TextColor="#97C459"
                       FontSize="11" FontAttributes="Bold"/>
            </Border>

        </Grid>

        <!-- ══════════════════════════════════════════════════
             CONTENIDO PRINCIPAL
        ══════════════════════════════════════════════════ -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,16" Spacing="0">

                <!-- ── ESTADO DE CARGA ──────────────────── -->
                <ActivityIndicator x:Name="LoadingIndicator"
                                   IsRunning="True"
                                   IsVisible="True"
                                   Color="{StaticResource AccentGreen}"
                                   HeightRequest="48"
                                   Margin="0,32,0,0"/>

                <!-- ── SIN TURNO ACTIVO ─────────────────── -->
                <VerticalStackLayout x:Name="PanelSinTurno"
                                     IsVisible="False"
                                     HorizontalOptions="Center"
                                     Spacing="12"
                                     Margin="0,40,0,0">

                    <Image Source="no_turno.png"
                           WidthRequest="80" HeightRequest="80"
                           HorizontalOptions="Center"
                           Opacity="0.5"/>

                    <Label Text="Sin turno activo"
                           TextColor="{StaticResource TextPrimary}"
                           FontSize="18" FontAttributes="Bold"
                           HorizontalOptions="Center"/>

                    <Label Text="No hay un turno nocturno registrado para hoy."
                           TextColor="{StaticResource TextSecondary}"
                           FontSize="13"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"
                           Margin="0,0,0,8"/>

                    <Button x:Name="BtnIniciarTurno"
                            Text="Iniciar turno de hoy"
                            BackgroundColor="{StaticResource AccentGreen}"
                            TextColor="#111111"
                            FontAttributes="Bold"
                            FontSize="15"
                            CornerRadius="12"
                            HeightRequest="52"
                            WidthRequest="240"
                            Clicked="OnIniciarTurnoClicked"/>

                </VerticalStackLayout>

                <!-- ── RONDINES DEL TURNO ───────────────── -->
                <VerticalStackLayout x:Name="PanelRondines"
                                     IsVisible="False"
                                     Spacing="0">

                    <!-- Encabezado sección -->
                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,12">
                        <Label Grid.Column="0"
                               Text="Rondines del turno"
                               TextColor="{StaticResource TextPrimary}"
                               FontSize="15" FontAttributes="Bold"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="1"
                               x:Name="LblConteoRondines"
                               Text="0/5 completados"
                               TextColor="{StaticResource TextSecondary}"
                               FontSize="12"
                               VerticalOptions="Center"/>
                    </Grid>

                    <!-- Lista de rondines (se llena desde code-behind) -->
                    <VerticalStackLayout x:Name="ListaRondines" Spacing="10"/>

                    <!-- Espaciado inferior para que el TabBar no tape contenido -->
                    <BoxView HeightRequest="24" Color="Transparent"/>

                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Toast flotante -->
        <Frame x:Name="ToastFrame"
               Grid.Row="0" Grid.RowSpan="2"
               BackgroundColor="#FF5555"
               CornerRadius="12" Padding="12,8"
               IsVisible="False"
               HorizontalOptions="Center"
               VerticalOptions="Start"
               Margin="24,56,24,0"
               HasShadow="True" Opacity="0"
               ZIndex="100">
            <Label x:Name="ToastLabel"
                   TextColor="White"
                   FontAttributes="Bold"
                   FontSize="13"
                   HorizontalOptions="Center"/>
        </Frame>

    </Grid>
</ContentPage>
