<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RocLandSecurity.Views.Guardia.ReportarIncidenciaPage"
             BackgroundColor="#111111"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="AccentGreen">#6DBF2E</Color>
            <Color x:Key="CardBg">#1A1A1A</Color>
            <Color x:Key="TextPrimary">#FFFFFF</Color>
            <Color x:Key="TextSecondary">#888888</Color>
            <Color x:Key="BorderColor">#2A2A2A</Color>
            <Color x:Key="InputBg">#1E1E1E</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ══ HEADER ══════════════════════════════════════════════════ -->
        <Grid Grid.Row="0"
              BackgroundColor="#1A1A1A"
              Padding="16,48,16,16"
              ColumnDefinitions="44,*,44">

            <Border Grid.Column="0"
                    BackgroundColor="#252525"
                    StrokeThickness="0"
                    WidthRequest="36" HeightRequest="36"
                    HorizontalOptions="Center"
                    VerticalOptions="Center">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <Image Source="back_arrow.png"
                        WidthRequest="24"
                        HeightRequest="24"
                        HorizontalOptions="Center"
                        VerticalOptions="Center">   
                    <Image.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnVolverClicked"/>
                    </Image.GestureRecognizers>
                </Image>
            </Border>

            <Label Grid.Column="1"
                   Text="Reportar Incidencia"
                   TextColor="{StaticResource TextPrimary}"
                   FontSize="17" FontAttributes="Bold"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"/>

        </Grid>

        <!-- ══ FORMULARIO ═══════════════════════════════════════════════ -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16,20,16,16" Spacing="20">

                <!-- ── SEVERIDAD ─────────────────────────────────────── -->
                <VerticalStackLayout Spacing="10">
                    <Label Text="Severidad"
                           TextColor="{StaticResource TextSecondary}"
                           FontSize="14"/>

                    <!-- Toggle de 3 opciones -->
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                        <Border Grid.Column="0"
                                x:Name="BtnBaja"
                                BackgroundColor="#252525"
                                StrokeThickness="1"
                                Stroke="#2A2A2A"
                                Padding="0,12"
                                HorizontalOptions="Fill">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Label Text="Baja"
                                   TextColor="{StaticResource TextSecondary}"
                                   FontSize="14"
                                   HorizontalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnSeveridadBajaClicked"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </Border>

                        <Border Grid.Column="1"
                                x:Name="BtnMedia"
                                BackgroundColor="{StaticResource AccentGreen}"
                                StrokeThickness="0"
                                Padding="0,12"
                                HorizontalOptions="Fill">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Label Text="Media"
                                   TextColor="#111111"
                                   FontSize="14" FontAttributes="Bold"
                                   HorizontalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnSeveridadMediaClicked"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </Border>

                        <Border Grid.Column="2"
                                x:Name="BtnAlta"
                                BackgroundColor="#252525"
                                StrokeThickness="1"
                                Stroke="#2A2A2A"
                                Padding="0,12"
                                HorizontalOptions="Fill">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Label Text="Alta"
                                   TextColor="{StaticResource TextSecondary}"
                                   FontSize="14"
                                   HorizontalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnSeveridadAltaClicked"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </Border>
                    </Grid>
                </VerticalStackLayout>

                <!-- ── UBICACIÓN ──────────────────────────────────────── -->
                <VerticalStackLayout Spacing="10">
                    <Label Text="Ubicación"
                           TextColor="{StaticResource TextSecondary}"
                           FontSize="14"/>

                    <!-- Selector de punto QR o libre -->
                    <Border BackgroundColor="{StaticResource InputBg}"
                            StrokeThickness="1"
                            Stroke="{StaticResource BorderColor}"
                            Padding="14,4"
                            HorizontalOptions="Fill">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="Auto,*">
                            <Image Grid.Column="0"
                                   Source="location.png"
                                   HeightRequest="14"
                                   WidthRequest="14"
                                   VerticalOptions="Center"
                                   Margin="0,0,8,0"/>
                            <Picker Grid.Column="1"
                                    x:Name="PickerPunto"
                                    Title="Ej: Estacionamiento Norte"
                                    TitleColor="{StaticResource TextSecondary}"
                                    TextColor="{StaticResource TextPrimary}"
                                    BackgroundColor="Transparent"
                                    HeightRequest="48"
                                    SelectedIndexChanged="OnPuntoSeleccionado"/>
                        </Grid>
                    </Border>

                    <!-- Ubicación libre (aparece si selecciona "Otra ubicación") -->
                    <Border x:Name="PanelUbicacionLibre"
                            IsVisible="False"
                            BackgroundColor="{StaticResource InputBg}"
                            StrokeThickness="1"
                            Stroke="{StaticResource BorderColor}"
                            Padding="14,4">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <Entry x:Name="EntryUbicacionLibre"
                               Placeholder="Describe la ubicación..."
                               PlaceholderColor="{StaticResource TextSecondary}"
                               TextColor="{StaticResource TextPrimary}"
                               BackgroundColor="Transparent"
                               FontSize="14"
                               HeightRequest="48"/>
                    </Border>
                </VerticalStackLayout>

                <!-- ── DESCRIPCIÓN ────────────────────────────────────── -->
                <VerticalStackLayout Spacing="10">
                    <Label Text="Descripción"
                           TextColor="{StaticResource TextSecondary}"
                           FontSize="14"/>

                    <Border BackgroundColor="{StaticResource InputBg}"
                            StrokeThickness="1"
                            Stroke="{StaticResource BorderColor}"
                            Padding="14,10">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <Editor x:Name="EditorDescripcion"
                                Placeholder="Describe la incidencia encontrada..."
                                PlaceholderColor="{StaticResource TextSecondary}"
                                TextColor="{StaticResource TextPrimary}"
                                BackgroundColor="Transparent"
                                FontSize="14"
                                HeightRequest="120"
                                AutoSize="Disabled"/>
                    </Border>
                </VerticalStackLayout>

                <!-- ── CONTEXTO (solo info, no editable) ─────────────── -->
                <Border x:Name="PanelContexto"
                        BackgroundColor="#1A1A1A"
                        StrokeThickness="1"
                        Stroke="#2A2A2A"
                        Padding="14,12"
                        IsVisible="False">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Contexto del reporte"
                               TextColor="{StaticResource TextSecondary}"
                               FontSize="12"/>
                        <Label x:Name="LblContexto"
                               Text="--"
                               TextColor="{StaticResource TextPrimary}"
                               FontSize="13"/>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ══ BOTÓN ENVIAR ══════════════════════════════════════════════ -->
        <Grid Grid.Row="2"
              BackgroundColor="#111111"
              Padding="16,12,16,40">
            <Button x:Name="BtnEnviar"
                BackgroundColor="#7B1A1A"
                TextColor="White"
                FontAttributes="Bold"
                FontSize="16"
                CornerRadius="14"
                HeightRequest="56"
                Clicked="OnEnviarClicked"
                ImageSource="send.png"
                ContentLayout="Left,10"
                Text="Enviar" />
        </Grid>

        <!-- Toast -->
        <Frame x:Name="ToastFrame"
               Grid.Row="0" Grid.RowSpan="3"
               BackgroundColor="#FF5555"
               CornerRadius="12" Padding="14,10"
               IsVisible="False"
               HorizontalOptions="Center"
               VerticalOptions="Start"
               Margin="20,56,20,0"
               HasShadow="True" Opacity="0"
               ZIndex="200">
            <Label x:Name="ToastLabel"
                   TextColor="White" FontAttributes="Bold"
                   FontSize="13" HorizontalOptions="Center"/>
        </Frame>

    </Grid>
</ContentPage>
