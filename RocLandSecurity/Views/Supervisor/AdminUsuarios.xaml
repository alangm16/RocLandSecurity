<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RocLandSecurity.Views.Supervisor.AdminUsuarios"
             BackgroundColor="#111111"
             Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="AccentGreen">#6DBF2E</Color>
            <Color x:Key="TextPrimary">#FFFFFF</Color>
            <Color x:Key="TextSecondary">#888888</Color>
            <Color x:Key="CardBackground">#1C1C1C</Color>
            <Color x:Key="BorderColor">#2A2A2A</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <!-- Raíz: permite superponer el overlay de modales -->
    <Grid>

        <!-- ══════════════════════════════════════════════════════════════
             CONTENIDO PRINCIPAL
             ══════════════════════════════════════════════════════════════ -->
        <Grid RowDefinitions="Auto,*">

            <!-- ── Header ──────────────────────────────────────────────── -->
            <Grid Grid.Row="0"
                  BackgroundColor="#1A1A1A"
                  Padding="20,48,20,16"
                  ColumnDefinitions="*,Auto">

                <VerticalStackLayout Grid.Column="0"
                                     VerticalOptions="Center"
                                     Spacing="2">
                    <Label Text="Guardias"
                           TextColor="{StaticResource TextPrimary}"
                           FontSize="22"
                           FontAttributes="Bold"/>
                    <Label x:Name="LblSubtitulo"
                           Text="Cargando..."
                           TextColor="{StaticResource TextSecondary}"
                           FontSize="12"/>
                </VerticalStackLayout>

                <Border Grid.Column="1"
                        BackgroundColor="#1E3A0F"
                        StrokeThickness="0"
                        WidthRequest="42" HeightRequest="42"
                        VerticalOptions="Center" HorizontalOptions="End">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="21"/>
                    </Border.StrokeShape>
                    <Image Source="user.png"
                           HeightRequest="24" WidthRequest="24"
                           HorizontalOptions="Center" VerticalOptions="Center">
                    </Image>
                </Border>
            </Grid>

            <!-- ── Contenido ───────────────────────────────────────────── -->
            <ScrollView Grid.Row="1">
                <VerticalStackLayout Spacing="0">

                    <!-- Barra de búsqueda + botón "+" -->
                    <Grid Padding="16,14,16,10"
                          ColumnDefinitions="*,Auto"
                          ColumnSpacing="10">

                        <Border Grid.Column="0"
                                BackgroundColor="#1A1A1A"
                                Stroke="{StaticResource AccentGreen}"
                                StrokeThickness="1.5"
                                HeightRequest="48">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="Auto,*" Padding="10,0">
                                <Image Grid.Column="0"
                                       Source="search.png"
                                       WidthRequest="14" HeightRequest="14"
                                       VerticalOptions="Center"/>
                                <Entry Grid.Column="1"
                                       Placeholder="Buscar guardia..."
                                       PlaceholderColor="{StaticResource TextSecondary}"
                                       Text="{Binding TextoBusqueda}"
                                       TextColor="{StaticResource AccentGreen}"
                                       BackgroundColor="Transparent"
                                       VerticalOptions="Center"
                                       FontSize="14"
                                       Margin="6,0,0,0"/>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1"
                                BackgroundColor="{StaticResource AccentGreen}"
                                StrokeThickness="0"
                                WidthRequest="48" HeightRequest="48">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Label Text="+"
                                   TextColor="Black"
                                   FontSize="28" FontAttributes="Bold"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnAgregarUsuarios"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </Border>
                    </Grid>

                    <!-- Indicador de carga -->
                    <ActivityIndicator x:Name="LoadingIndicator"
                                       IsRunning="True" IsVisible="True"
                                       Color="{StaticResource AccentGreen}"
                                       HeightRequest="48"
                                       Margin="0,24,0,0"/>

                    <!-- Lista de guardias -->
                    <CollectionView x:Name="ListaUsuarios"
                                    ItemsSource="{Binding Usuarios}"
                                    Margin="16,4,16,32"
                                    SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="0,5,0,5">
                                    <Border BackgroundColor="{StaticResource CardBackground}"
                                            Stroke="{StaticResource BorderColor}"
                                            StrokeThickness="1"
                                            Padding="14,12">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="12"/>
                                        </Border.StrokeShape>

                                        <Grid ColumnDefinitions="Auto,*,Auto,Auto"
                                              ColumnSpacing="12"
                                              VerticalOptions="Center">

                                            <!-- Ícono circular -->
                                            <Border Grid.Column="0"
                                                    BackgroundColor="#1E3A0F"
                                                    StrokeThickness="0"
                                                    WidthRequest="42" HeightRequest="42"
                                                    VerticalOptions="Center">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="21"/>
                                                </Border.StrokeShape>
                                                <Image Source="shield.png"
                                                       HeightRequest="24" WidthRequest="24"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center"/>
                                            </Border>

                                            <!-- Datos del usuario -->
                                            <VerticalStackLayout Grid.Column="1"
                                                                 VerticalOptions="Center"
                                                                 Spacing="3">

                                                <HorizontalStackLayout Spacing="8">
                                                    <Label Text="{Binding Nombre}"
                                                           TextColor="{StaticResource TextPrimary}"
                                                           FontSize="14" FontAttributes="Bold"
                                                           VerticalOptions="Center"/>

                                                    <!-- Badge Activo -->
                                                    <Border BackgroundColor="#1E3A0F"
                                                            StrokeThickness="0"
                                                            Padding="6,2"
                                                            VerticalOptions="Center"
                                                            IsVisible="{Binding EsActivo}">
                                                        <Border.StrokeShape>
                                                            <RoundRectangle CornerRadius="5"/>
                                                        </Border.StrokeShape>
                                                        <Label Text="Activo"
                                                               TextColor="{StaticResource AccentGreen}"
                                                               FontSize="11" FontAttributes="Bold"/>
                                                    </Border>

                                                    <!-- Badge Inactivo -->
                                                    <Border BackgroundColor="#2A2A2A"
                                                            StrokeThickness="0"
                                                            Padding="6,2"
                                                            VerticalOptions="Center"
                                                            IsVisible="{Binding EsInactivo}">
                                                        <Border.StrokeShape>
                                                            <RoundRectangle CornerRadius="5"/>
                                                        </Border.StrokeShape>
                                                        <Label Text="Inactivo"
                                                               TextColor="{StaticResource TextSecondary}"
                                                               FontSize="11"/>
                                                    </Border>
                                                </HorizontalStackLayout>

                                                <!-- Código · @usuario -->
                                                <Label TextColor="{StaticResource TextSecondary}"
                                                       FontSize="12">
                                                    <Label.FormattedText>
                                                        <FormattedString>
                                                            <Span Text="{Binding Codigo}"/>
                                                            <Span Text=" · @"/>
                                                            <Span Text="{Binding UsuarioLogin}"/>
                                                            <Span Text=" · "/>
                                                            <Span Text="{Binding RolTexto}"/>
                                                        </FormattedString>
                                                    </Label.FormattedText>
                                                </Label>

                                                <!-- Fecha de ingreso -->
                                                <Label TextColor="{StaticResource TextSecondary}"
                                                       FontSize="11">
                                                    <Label.FormattedText>
                                                        <FormattedString>
                                                            <Span Text="Ingreso: "/>
                                                            <Span Text="{Binding FechaIngreso}"/>
                                                        </FormattedString>
                                                    </Label.FormattedText>
                                                </Label>

                                            </VerticalStackLayout>

                                            <!-- Botón Editar -->
                                            <ImageButton Grid.Column="2"
                                                         Source="edit.png"
                                                         BackgroundColor="Transparent"
                                                         WidthRequest="22" HeightRequest="22"
                                                         VerticalOptions="Center"
                                                         CommandParameter="{Binding .}"
                                                         Clicked="OnEditarUsuario"/>

                                            <!-- Botón Eliminar -->
                                            <ImageButton Grid.Column="3"
                                                         Source="delete.png"
                                                         BackgroundColor="Transparent"
                                                         WidthRequest="22" HeightRequest="22"
                                                         VerticalOptions="Center"
                                                         CommandParameter="{Binding .}"
                                                         Clicked="OnEliminarUsuario"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </ScrollView>

            <!-- Toast -->
            <Frame x:Name="ToastFrame"
                   Grid.Row="0" Grid.RowSpan="2"
                   BackgroundColor="#FF5555"
                   CornerRadius="12" Padding="12,8"
                   IsVisible="False"
                   HorizontalOptions="Center"
                   VerticalOptions="Start"
                   Margin="24,56,24,0"
                   HasShadow="True" Opacity="0"
                   ZIndex="100">
                <Label x:Name="ToastLabel"
                       TextColor="White"
                       FontAttributes="Bold"
                       FontSize="13"
                       HorizontalOptions="Center"/>
            </Frame>

        </Grid>

        <!-- ══════════════════════════════════════════════════════════════
             MODAL OVERLAY — fondo semitransparente
             ══════════════════════════════════════════════════════════════ -->
        <Grid x:Name="ModalOverlay"
              IsVisible="False"
              BackgroundColor="#AA000000"
              ZIndex="200">

            <!-- ── MODAL AGREGAR ──────────────────────────────────────── -->
            <Border x:Name="ModalAgregar"
                    IsVisible="False"
                    BackgroundColor="#1C1C1C"
                    Stroke="#2A2A2A"
                    StrokeThickness="1"
                    Padding="24,20"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    WidthRequest="340">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16"/>
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="16">

                    <!-- Título + cerrar -->
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0"
                               Text="Nuevo Guardia"
                               TextColor="White"
                               FontSize="17" FontAttributes="Bold"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="1"
                               Text="✕"
                               TextColor="#888888"
                               FontSize="18"
                               VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnCerrarModal"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>

                    <!-- Nombre completo -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Nombre completo"
                               TextColor="#888888" FontSize="12"/>
                        <Border BackgroundColor="#111111"
                                Stroke="{StaticResource AccentGreen}"
                                StrokeThickness="1.5"
                                HeightRequest="44">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8"/>
                            </Border.StrokeShape>
                            <Entry x:Name="EntryAgregarNombre"
                                   Placeholder="Ej. Carlos Méndez"
                                   PlaceholderColor="#555555"
                                   TextColor="White"
                                   BackgroundColor="Transparent"
                                   FontSize="14"
                                   Margin="10,0"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Usuario (login) -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Nombre de usuario"
                               TextColor="#888888" FontSize="12"/>
                        <Border BackgroundColor="#111111"
                                Stroke="#2A2A2A"
                                StrokeThickness="1"
                                HeightRequest="44">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8"/>
                            </Border.StrokeShape>
                            <Entry x:Name="EntryAgregarUsuario"
                                   Placeholder="Ej. cmendes"
                                   PlaceholderColor="#555555"
                                   TextColor="White"
                                   BackgroundColor="Transparent"
                                   FontSize="14"
                                   Margin="10,0"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Contraseña -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Contraseña"
                               TextColor="#888888" FontSize="12"/>
                        <Border BackgroundColor="#111111"
                                Stroke="#2A2A2A"
                                StrokeThickness="1"
                                HeightRequest="44">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8"/>
                            </Border.StrokeShape>
                            <Entry x:Name="EntryAgregarContrasena"
                                   Placeholder="Mínimo 8 caracteres"
                                   PlaceholderColor="#555555"
                                   TextColor="White"
                                   BackgroundColor="Transparent"
                                   IsPassword="True"
                                   FontSize="14"
                                   Margin="10,0"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- QR Code (opcional) -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Código QR (opcional)"
                               TextColor="#888888" FontSize="12"/>
                        <Border BackgroundColor="#111111"
                                Stroke="#2A2A2A"
                                StrokeThickness="1"
                                HeightRequest="44">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8"/>
                            </Border.StrokeShape>
                            <Entry x:Name="EntryAgregarQR"
                                   Placeholder="Ej. QR005"
                                   PlaceholderColor="#555555"
                                   TextColor="White"
                                   BackgroundColor="Transparent"
                                   FontSize="14"
                                   Margin="10,0"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Botones -->
                    <Border BackgroundColor="{StaticResource AccentGreen}"
                            StrokeThickness="0"
                            HeightRequest="48">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Label Text="Agregar"
                               TextColor="Black"
                               FontAttributes="Bold"
                               FontSize="15"
                               HorizontalOptions="Center"
                               VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnConfirmarAgregar"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>

                    <Border BackgroundColor="#2A2A2A"
                            StrokeThickness="0"
                            HeightRequest="44">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Label Text="Cancelar"
                               TextColor="White"
                               FontSize="15"
                               HorizontalOptions="Center"
                               VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnCerrarModal"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>

                </VerticalStackLayout>
            </Border>

            <!-- ── MODAL EDITAR ───────────────────────────────────────── -->
            <Border x:Name="ModalEditar"
                    IsVisible="False"
                    BackgroundColor="#1C1C1C"
                    Stroke="#2A2A2A"
                    StrokeThickness="1"
                    Padding="24,20"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    WidthRequest="340">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16"/>
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="16">

                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0"
                               Text="Editar Guardia"
                               TextColor="White"
                               FontSize="17" FontAttributes="Bold"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="1"
                               Text="✕"
                               TextColor="#888888"
                               FontSize="18"
                               VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnCerrarModal"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>

                    <!-- Nombre completo -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Nombre completo"
                               TextColor="#888888" FontSize="12"/>
                        <Border BackgroundColor="#111111"
                                Stroke="{StaticResource AccentGreen}"
                                StrokeThickness="1.5"
                                HeightRequest="44">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8"/>
                            </Border.StrokeShape>
                            <Entry x:Name="EntryEditarNombre"
                                   TextColor="White"
                                   BackgroundColor="Transparent"
                                   FontSize="14"
                                   Margin="10,0"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Usuario login -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Nombre de usuario"
                               TextColor="#888888" FontSize="12"/>
                        <Border BackgroundColor="#111111"
                                Stroke="#2A2A2A"
                                StrokeThickness="1"
                                HeightRequest="44">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8"/>
                            </Border.StrokeShape>
                            <Entry x:Name="EntryEditarUsuario"
                                   TextColor="White"
                                   BackgroundColor="Transparent"
                                   FontSize="14"
                                   Margin="10,0"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Nueva contraseña (opcional) -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Nueva contraseña (dejar vacío para no cambiar)"
                               TextColor="#888888" FontSize="11"/>
                        <Border BackgroundColor="#111111"
                                Stroke="#2A2A2A"
                                StrokeThickness="1"
                                HeightRequest="44">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8"/>
                            </Border.StrokeShape>
                            <Entry x:Name="EntryEditarContrasena"
                                   Placeholder="••••••"
                                   PlaceholderColor="#555555"
                                   TextColor="White"
                                   BackgroundColor="Transparent"
                                   IsPassword="True"
                                   FontSize="14"
                                   Margin="10,0"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- QR Code -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Código QR (opcional)"
                               TextColor="#888888" FontSize="12"/>
                        <Border BackgroundColor="#111111"
                                Stroke="#2A2A2A"
                                StrokeThickness="1"
                                HeightRequest="44">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8"/>
                            </Border.StrokeShape>
                            <Entry x:Name="EntryEditarQR"
                                   TextColor="White"
                                   BackgroundColor="Transparent"
                                   FontSize="14"
                                   Margin="10,0"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Botones -->
                    <Border BackgroundColor="{StaticResource AccentGreen}"
                            StrokeThickness="0"
                            HeightRequest="48">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Label Text="Guardar"
                               TextColor="Black"
                               FontAttributes="Bold"
                               FontSize="15"
                               HorizontalOptions="Center"
                               VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnConfirmarEditar"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>

                    <Border BackgroundColor="#2A2A2A"
                            StrokeThickness="0"
                            HeightRequest="44">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Label Text="Cancelar"
                               TextColor="White"
                               FontSize="15"
                               HorizontalOptions="Center"
                               VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnCerrarModal"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>

                </VerticalStackLayout>
            </Border>

            <!-- ── MODAL ELIMINAR ─────────────────────────────────────── -->
            <Border x:Name="ModalEliminar"
                    IsVisible="False"
                    BackgroundColor="#1C1C1C"
                    Stroke="#2A2A2A"
                    StrokeThickness="1"
                    Padding="24,20"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    WidthRequest="320">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16"/>
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="16">

                    <Label Text="Eliminar Guardia"
                           TextColor="White"
                           FontSize="17" FontAttributes="Bold"
                           HorizontalOptions="Center"/>

                    <Label x:Name="LblEliminarMensaje"
                           TextColor="#CCCCCC"
                           FontSize="14"
                           HorizontalTextAlignment="Center"/>

                    <!-- Botón Eliminar (rojo) -->
                    <Border BackgroundColor="#CC2222"
                            StrokeThickness="0"
                            HeightRequest="48">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Label Text="Eliminar"
                               TextColor="White"
                               FontAttributes="Bold"
                               FontSize="15"
                               HorizontalOptions="Center"
                               VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnConfirmarEliminar"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>

                    <Border BackgroundColor="#111111"
                            StrokeThickness="0"
                            HeightRequest="44">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Label Text="Cancelar"
                               TextColor="White"
                               FontSize="15"
                               HorizontalOptions="Center"
                               VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnCerrarModal"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>

                </VerticalStackLayout>
            </Border>

        </Grid>
        <!-- fin ModalOverlay -->

    </Grid>
</ContentPage>
