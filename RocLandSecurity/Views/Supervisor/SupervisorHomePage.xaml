<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RocLandSecurity.Views.Supervisor.SupervisorHomePage"
             BackgroundColor="#111111"
             Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="AccentGreen">#6DBF2E</Color>
            <Color x:Key="CardBg">#1C1C1C</Color>
            <Color x:Key="TextPrimary">#FFFFFF</Color>
            <Color x:Key="TextSecondary">#888888</Color>
            <Color x:Key="BorderColor">#2E2E2E</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">

        <!-- ══════════════════════════════════════════════════
             HEADER
        ══════════════════════════════════════════════════ -->
        <Grid Grid.Row="0"
              BackgroundColor="#1C1C1C"
              Padding="20,48,20,16"
              ColumnDefinitions="*,Auto">

            <VerticalStackLayout Grid.Column="0" Spacing="2">
                <Label Text="Panel de control"
                       TextColor="{StaticResource TextSecondary}"
                       FontSize="13"/>
                <Label x:Name="LblNombreSupervisor"
                       Text="--"
                       TextColor="{StaticResource TextPrimary}"
                       FontSize="20" FontAttributes="Bold"/>
                <Label x:Name="LblFechaHoy"
                       Text="--"
                       TextColor="{StaticResource TextSecondary}"
                       FontSize="12"/>
            </VerticalStackLayout>

            <!-- Botón refrescar -->
            <Button Grid.Column="1"
                    Text="↻"
                    FontSize="20"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource AccentGreen}"
                    WidthRequest="44" HeightRequest="44"
                    Clicked="OnRefrescarClicked"/>
        </Grid>

        <!-- ══════════════════════════════════════════════════
             CONTENIDO
        ══════════════════════════════════════════════════ -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,16" Spacing="0">

                <!-- ── CARGANDO ─────────────────────────── -->
                <ActivityIndicator x:Name="LoadingIndicator"
                                   IsRunning="True"
                                   IsVisible="True"
                                   Color="{StaticResource AccentGreen}"
                                   HeightRequest="48"
                                   Margin="0,32,0,0"/>

                <!-- ── CONTENIDO PRINCIPAL ──────────────── -->
                <VerticalStackLayout x:Name="PanelContenido"
                                     IsVisible="False"
                                     Spacing="0">

                    <!-- Turno nocturno label -->
                    <Label Text="Turno nocturno 20:00 – 06:00"
                           TextColor="{StaticResource TextSecondary}"
                           FontSize="12"
                           Margin="0,0,0,12"/>

                    <!-- ── TARJETAS DE MÉTRICAS (2x2) ──── -->
                    <Grid ColumnDefinitions="*,*"
                          RowDefinitions="Auto,Auto"
                          ColumnSpacing="10"
                          RowSpacing="10"
                          Margin="0,0,0,20">

                        <!-- Completados -->
                        <Border Grid.Row="0" Grid.Column="0"
                                BackgroundColor="#0a1a0a"
                                StrokeThickness="1" Stroke="#3B6D11"
                                Padding="14,12">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="2">
                                <Label x:Name="LblCompletados"
                                       Text="0"
                                       TextColor="#97C459"
                                       FontSize="28" FontAttributes="Bold"/>
                                <Label Text="Completados"
                                       TextColor="#97C459"
                                       FontSize="11" Opacity="0.8"/>
                            </VerticalStackLayout>
                        </Border>

                        <!-- En progreso -->
                        <Border Grid.Row="0" Grid.Column="1"
                                BackgroundColor="#0a1a2e"
                                StrokeThickness="1" Stroke="#185FA5"
                                Padding="14,12">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="2">
                                <Label x:Name="LblEnProgreso"
                                       Text="0"
                                       TextColor="#85B7EB"
                                       FontSize="28" FontAttributes="Bold"/>
                                <Label Text="En progreso"
                                       TextColor="#85B7EB"
                                       FontSize="11" Opacity="0.8"/>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Pendientes -->
                        <Border Grid.Row="1" Grid.Column="0"
                                BackgroundColor="#2a2400"
                                StrokeThickness="1" Stroke="#BA7517"
                                Padding="14,12">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="2">
                                <Label x:Name="LblPendientes"
                                       Text="0"
                                       TextColor="#FAC775"
                                       FontSize="28" FontAttributes="Bold"/>
                                <Label Text="Pendientes"
                                       TextColor="#FAC775"
                                       FontSize="11" Opacity="0.8"/>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Con incidencia -->
                        <Border Grid.Row="1" Grid.Column="1"
                                BackgroundColor="#2a0a0a"
                                StrokeThickness="1" Stroke="#A32D2D"
                                Padding="14,12">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="2">
                                <Label x:Name="LblIncidencias"
                                       Text="0"
                                       TextColor="#F09595"
                                       FontSize="28" FontAttributes="Bold"/>
                                <Label Text="Con incidencia"
                                       TextColor="#F09595"
                                       FontSize="11" Opacity="0.8"/>
                            </VerticalStackLayout>
                        </Border>

                    </Grid>

                    <!-- ── LISTA DE RONDINES ─────────────── -->
                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,12">
                        <Label Grid.Column="0"
                               Text="Rondines del turno"
                               TextColor="{StaticResource TextPrimary}"
                               FontSize="15" FontAttributes="Bold"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="1"
                               x:Name="LblTotalRondines"
                               Text="--"
                               TextColor="{StaticResource TextSecondary}"
                               FontSize="12"
                               VerticalOptions="Center"/>
                    </Grid>

                    <!-- Sin rondines hoy -->
                    <VerticalStackLayout x:Name="PanelSinRondines"
                                         IsVisible="False"
                                         HorizontalOptions="Center"
                                         Spacing="8"
                                         Margin="0,20,0,0">
                        <Label Text="No hay rondines registrados hoy"
                               TextColor="{StaticResource TextSecondary}"
                               FontSize="14"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"/>
                        <Label Text="El guardia debe iniciar su turno para generar los rondines."
                               TextColor="{StaticResource TextSecondary}"
                               FontSize="12" Opacity="0.6"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>

                    <!-- Cards de rondines (se construyen desde code-behind) -->
                    <VerticalStackLayout x:Name="ListaRondines" Spacing="10"/>

                    <BoxView HeightRequest="24" Color="Transparent"/>

                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Toast -->
        <Frame x:Name="ToastFrame"
               Grid.Row="0" Grid.RowSpan="2"
               BackgroundColor="#FF5555"
               CornerRadius="12" Padding="12,8"
               IsVisible="False"
               HorizontalOptions="Center"
               VerticalOptions="Start"
               Margin="24,56,24,0"
               HasShadow="True" Opacity="0"
               ZIndex="100">
            <Label x:Name="ToastLabel"
                   TextColor="White"
                   FontAttributes="Bold"
                   FontSize="13"
                   HorizontalOptions="Center"/>
        </Frame>

    </Grid>
</ContentPage>
