<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RocLandSecurity.Views.Supervisor.SupervisorIncidenciasPage"
             BackgroundColor="#111111"
             Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="AccentGreen">#6DBF2E</Color>
            <Color x:Key="CardBg">#1C1C1C</Color>
            <Color x:Key="TextPrimary">#FFFFFF</Color>
            <Color x:Key="TextSecondary">#888888</Color>
            <Color x:Key="BorderColor">#2E2E2E</Color>
            <Color x:Key="AbiertaBg">#2a0a0a</Color>
            <Color x:Key="ResueltaBg">#0a1a0a</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">

        <!-- HEADER -->
        <Grid Grid.Row="0"
              BackgroundColor="#1C1C1C"
              Padding="20,48,20,16"
              ColumnDefinitions="*,Auto">

            <VerticalStackLayout Grid.Column="0" Spacing="2">
                <Label Text="Incidencias"
                       TextColor="{StaticResource TextPrimary}"
                       FontSize="20" FontAttributes="Bold"/>
                <Label x:Name="LblPeriodo"
                       Text="Últimos 7 días"
                       TextColor="{StaticResource TextSecondary}"
                       FontSize="12"/>
            </VerticalStackLayout>

            <Button Grid.Column="1"
                    BackgroundColor="Transparent"
                    WidthRequest="24"
                    HeightRequest="24"
                    Clicked="OnRefrescarClicked"
                    Padding="0"
                    CornerRadius="22">
                <Button.ImageSource>
                    <FileImageSource File="refresh.png" />
                </Button.ImageSource>
            </Button>
        </Grid>

        <!-- CONTENIDO -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16,16,16,32" Spacing="0">

                <!-- CARGANDO -->
                <ActivityIndicator x:Name="LoadingIndicator"
                                   IsRunning="True"
                                   IsVisible="True"
                                   Color="{StaticResource AccentGreen}"
                                   HeightRequest="48"
                                   Margin="0,32,0,0"/>

                <!-- CONTENIDO PRINCIPAL -->
                <VerticalStackLayout x:Name="PanelContenido"
                                     IsVisible="False"
                                     Spacing="0">

                    <!-- Sin incidencias -->
                    <VerticalStackLayout x:Name="PanelSinIncidencias"
                                         IsVisible="False"
                                         HorizontalOptions="Center"
                                         Spacing="10"
                                         Margin="0,48,0,0">
                        <Label Text="📋" FontSize="48" HorizontalOptions="Center"/>
                        <Label Text="No hay incidencias reportadas"
                               TextColor="{StaticResource TextPrimary}"
                               FontSize="16" FontAttributes="Bold"
                               HorizontalOptions="Center"/>
                        <Label Text="En los últimos 7 días no se han reportado incidencias."
                               TextColor="{StaticResource TextSecondary}"
                               FontSize="13"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>

                    <!-- Lista de incidencias agrupadas por día -->
                    <VerticalStackLayout x:Name="ListaIncidencias" Spacing="16"/>

                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Toast -->
        <Frame x:Name="ToastFrame"
               Grid.Row="0" Grid.RowSpan="2"
               BackgroundColor="#FF5555"
               CornerRadius="12" Padding="12,8"
               IsVisible="False"
               HorizontalOptions="Center"
               VerticalOptions="Start"
               Margin="24,56,24,0"
               HasShadow="True" Opacity="0"
               ZIndex="100">
            <Label x:Name="ToastLabel"
                   TextColor="White"
                   FontAttributes="Bold"
                   FontSize="13"
                   HorizontalOptions="Center"/>
        </Frame>

    </Grid>
</ContentPage>